{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "noEmit": true
  },
  "include": [
    "components/**/*.ts",
    "config/**/*.ts",
    "fixtures/**/*.ts",
    "generators/**/*.ts",
    "http-clients/**/*.ts",
    "pages/**/*.ts",
    "tests/**/*.ts",
    "types/**/*.ts",
    "utils/**/*.ts",
    "playwright.config.ts"
  ]
}
